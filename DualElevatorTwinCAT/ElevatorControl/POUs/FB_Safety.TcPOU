      <LineId Id="34" Count="12" />
      <LineId Id="5" Count="0" />
    </LineIds>
    <LineIds Name="FB_Safety.GetAlarmLog">
      <LineId Id="5" Count="0" />
    </LineIds>
    <LineIds Name="FB_Safety.GetCurrentDateTime">
      <LineId Id="20" Count="4" />
      <LineId Id="5" Count="0" />
    </LineIds>
    <LineIds Name="FB_Safety.ResetSystemAlarm">
      <LineId Id="21" Count="19" />
      <LineId Id="5" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>